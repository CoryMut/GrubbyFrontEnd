# Copy this file to .env.local for local development (never commit .env.local)
# These are baked into the build at compile time by Create React App.

# Backend API base URL
REACT_APP_SERVER_URL=https://grubbybackend-production.up.railway.app

# CDN base URL (DigitalOcean Spaces or other)
REACT_APP_CDN=https://grubbythegrape.sfo2.cdn.digitaloceanspaces.com
